<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tunkbook.mapper.CategoryMapper">
    <select id="list" resultType="com.tunkbook.pojo.Categories" resultMap="categoryAndSubcategory">
        select c.id,
               c.category_name,
               c.create_time,
               c.update_time,
               sc.id as sub_id,
                sc.category_id,
               sc.subcategory_name
        from category c
        left join subcategory sc on c.id=sc.category_id
    </select>
    
    <resultMap id="categoryAndSubcategory" type="com.tunkbook.pojo.Categories">
        <!--select nombre de categorias-->
        <id property="id" column="id" />
        <result property="categoryName" column="category_name"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        
        <!--select sub categoria corresponde a categoria-->
        <collection property="subCategoriesList" ofType="com.tunkbook.pojo.SubCategories">
            <id property="id" column="sub_id"/>
            <result property="categoryId" column="category_id"/>
            <result property="subcategoryName" column="subcategory_name"/>
        </collection>
    </resultMap>
</mapper>
